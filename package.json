{
  "name": "esg-carbon-report-assistant",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/next/dist/bin/next lint",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "node ./node_modules/tsx/dist/cli.mjs src/lib/calculation-engine.test.ts",
    "db:generate": "node ./node_modules/prisma/build/index.js generate",
    "db:migrate": "node ./node_modules/prisma/build/index.js migrate dev",
    "db:seed": "node ./node_modules/tsx/dist/cli.mjs prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "exceljs": "^4.4.0",
    "iconv-lite": "^0.7.2",
    "next": "^14.2.20",
    "pdfkit": "^0.15.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.8",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
